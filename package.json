{
  "name": "tyofflinejs",
  "version": "0.2.0",
  "description": "Cross-platform offline-first module for React and React Native with pluggable storage/network adapters",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./web": {
      "import": {
        "types": "./dist/adapters.web.d.mts",
        "default": "./dist/adapters.web.mjs"
      },
      "require": {
        "types": "./dist/adapters.web.d.cts",
        "default": "./dist/adapters.web.cjs"
      }
    },
    "./native": {
      "import": {
        "types": "./dist/adapters.native.d.mts",
        "default": "./dist/adapters.native.mjs"
      },
      "require": {
        "types": "./dist/adapters.native.d.cts",
        "default": "./dist/adapters.native.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "e2e:app": "vite --config e2e/app/vite.config.ts",
    "e2e:test": "playwright test --config e2e/playwright.config.ts",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:mobile:install": "cd e2e-mobile && npm install",
    "e2e:mobile:start": "cd e2e-mobile && npx expo start",
    "e2e:mobile:ios": "cd e2e-mobile && npx expo start --ios",
    "e2e:mobile:android": "cd e2e-mobile && npx expo start --android",
    "e2e:mobile:test": "cd e2e-mobile && maestro test maestro/"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "@react-native-async-storage/async-storage": ">=1.0.0",
    "@react-native-community/netinfo": ">=9.0.0",
    "react-native-mmkv": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "@react-native-community/netinfo": {
      "optional": true
    },
    "react-native-mmkv": {
      "optional": true
    }
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "@testing-library/react": "^16.1.0",
    "jsdom": "^25.0.0",
    "@playwright/test": "^1.49.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0"
  },
  "keywords": [
    "offline",
    "offline-first",
    "react",
    "react-native",
    "sync",
    "queue",
    "cross-platform",
    "typescript"
  ],
  "homepage": "https://github.com/Ky0-Nguyen/tyofflinejs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ky0-Nguyen/tyofflinejs.git"
  },
  "bugs": {
    "url": "https://github.com/Ky0-Nguyen/tyofflinejs/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
